  "keyFeatures": [
    "177 detection rules across 13 security categories",
    "4-layer analysis engine (pattern matching, NLP, taint tracking, rug-pull detection)",
    "MCP client auto-discovery across 17 platforms",
    "Confidence scoring (0.0-1.0) for every finding",
    "CI-ready with JSON, SARIF, and Markdown output",
    "GitHub Action with SARIF upload",
    "Custom YAML rules without code",
    "Go library API for embedding in other tools",
    "Fully offline, no API keys or cloud required",
    "Deterministic and reproducible scans"
  ],
  "publicApiSurface": [
    "aguara scan [path]",
    "aguara discover",
    "aguara list-rules",
    "aguara explain <RULE_ID>",
    "aguara init [path]",
    "aguara version",
    "aguara.Scan(ctx, path, ...opts)",
    "aguara.ScanContent(ctx, content, filename, ...opts)",
    "aguara.Discover()",
    "aguara.ListRules(...opts)",
    "aguara.ExplainRule(id, ...opts)"
  ]
